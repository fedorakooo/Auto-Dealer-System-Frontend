{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["src/shared/*"],
      "@layouts/*": ["src/layouts/*"],
      "@widgets/*": ["src/widgets/*"],
      "@features/*": ["src/features/*"]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "checkJs": true,
    "noEmit": true,
    "allowJs": true
  },
  "include": ["src"]
}
